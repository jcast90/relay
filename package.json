{
  "name": "agent-harness",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "agent-harness": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "demo": "tsx src/cli.ts",
    "demo:live": "HARNESS_LIVE=1 tsx src/cli.ts",
    "list-runs": "tsx src/cli.ts list-runs",
    "status": "tsx src/cli.ts status",
    "up": "tsx src/cli.ts up",
    "tui": "tsx src/cli.ts tui",
    "tui:build": "cd tui && cargo build --release",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^3.24.4"
  }
}
