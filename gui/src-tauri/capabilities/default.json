{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Relay GUI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    }
  ]
}
